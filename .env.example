# Hatcher Frontend Environment Variables

# API Backend URL
NEXT_PUBLIC_API_URL=http://localhost:3001

# Documentation site URL
NEXT_PUBLIC_DOCS_URL=http://localhost:3003

# Solana RPC endpoint (read-only chain queries).
# ⚠ NEVER put a private RPC API key here. NEXT_PUBLIC_* is baked into
# the client bundle and becomes publicly readable. Leave unset to use
# the public mainnet-beta endpoint, or set a URL without secrets.
# If you need an authenticated RPC, proxy it through the backend.
NEXT_PUBLIC_SOLANA_RPC=https://api.mainnet-beta.solana.com

# Treasury wallet for payments
NEXT_PUBLIC_TREASURY_WALLET=

# Allow mock payments in development (set to "true" for dev)
NEXT_PUBLIC_ALLOW_MOCK_PAYMENTS=true
